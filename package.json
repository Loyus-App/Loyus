    "@kichiyaki/react-native-barcode-generator": "^0.6.7",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.3.1",
    "expo": "55",
    "expo-brightness": "~55.0.13",
    "expo-build-properties": "~55.0.13",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-file-system": "^55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-keep-awake": "~55.0.6",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-modules-core": "~55.0.22",
    "expo-router": "~55.0.12",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "i18next": "^26.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.3",
    "react-native": "0.83.4",
    "react-native-edge-to-edge": "^1.8.1",
