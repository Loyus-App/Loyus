    "@types/node": "^25.6.0",
    "@types/react": "~19.2.10",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "lint-staged": "^16.4.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
