{
  "name": "loyus",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ios": "npx expo run:ios",
    "android": "npx expo run:android",
    "start": "npx expo start --dev-client",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "npx tsc --noEmit",
    "test": "npx jest --passWithNoTests",
    "test:e2e": "bash scripts/test-e2e.sh",
    "test:e2e:studio": "maestro studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yaml,yml}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
